{
  "name": "backend",
  "version": "1.0.0",
  "description": "Sales Transformation Engine Backend",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bullmq": "^5.x",
    "cors": "^2.8.x",
    "dotenv": "^16.x",
    "exceljs": "^4.4.x",
    "express": "^4.21.x",
    "helmet": "^8.x",
    "ioredis": "^5.x",
    "knex": "^3.1.x",
    "morgan": "^1.10.x",
    "multer": "^1.4.x",
    "pg": "^8.13.x",
    "uuid": "^10.x",
    "winston": "^3.x",
    "zod": "^3.x"
  },
  "devDependencies": {
    "@types/cors": "^2.x",
    "@types/express": "^5.x",
    "@types/morgan": "^1.x",
    "@types/multer": "^1.x",
    "@types/pg": "^8.x",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.x",
    "@typescript-eslint/eslint-plugin": "^8.x",
    "@typescript-eslint/parser": "^8.x",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.x",
    "nodemon": "^3.x",
    "prettier": "^3.x",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.x",
    "typescript": "^5.x",
    "vitest": "^4.1.10"
  }
}
